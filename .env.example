# Husqvarna API credentials
HQ_API_KEY=replace-with-api-key
HQ_API_SECRET=replace-with-api-secret
PORT=3000

# Direct local runtime and integration-test databases
DATABASE_URL=postgresql://automower:replace-with-password@127.0.0.1:5432/automower
TEST_DATABASE_URL=postgresql://automower_test:replace-with-test-password@127.0.0.1:5432/automower_test

# Optional PostgreSQL client settings
PG_SSL=disable
PG_POOL_MAX=10
PG_IDLE_TIMEOUT_MS=30000
PG_CONNECTION_TIMEOUT_MS=5000
PG_QUERY_TIMEOUT_MS=10000

# Docker Compose development database values
POSTGRES_DB=automower
POSTGRES_USER=automower
POSTGRES_PASSWORD=replace-with-local-compose-password
POSTGRES_PORT=5433
